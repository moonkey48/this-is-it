{
  "manifest_version": 3,
  "name": "Context Capture",
  "description": "Select part of a Chrome page and send URL, text, and DOM context to Codex or Claude Code.",
  "version": "0.1.0",
  "permissions": ["activeTab", "clipboardWrite", "nativeMessaging", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Capture web context"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "capture-context": {
      "description": "Capture web context",
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "css": ["content-style.css"],
      "run_at": "document_idle"
    }
  ]
}
