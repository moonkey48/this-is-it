{
  "manifest_version": 3,
  "name": "Context Capture",
  "description": "Select part of a Chrome page and copy URL, text, links, images, and DOM context as Markdown.",
  "version": "0.2.0",
  "permissions": ["activeTab", "clipboardWrite", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Capture web context",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "start-capture": {
      "description": "Capture web context",
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      }
    }
  }
}
